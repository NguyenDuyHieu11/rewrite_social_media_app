# ---- Shared ----
APP_ENV=dev
LOG_LEVEL=debug

# ---- Postgres ----
POSTGRES_DSN=postgres://app:app@localhost:5432/social?sslmode=disable

# ---- Redis ----
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- MinIO ----
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=media
MINIO_USE_SSL=false

# ---- Auth ----
JWT_SECRET=change-me-in-production-please-32-bytes-minimum
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ---- Gateway ----
GATEWAY_ID=gateway-1
GATEWAY_ADDR=:8081
GATEWAY_PUBLIC_URL=http://localhost:8081

# ---- Dispatcher ----
DISPATCHER_ADDR=:8080

# ---- Presence ----
PRESENCE_HEARTBEAT_INTERVAL=30s
PRESENCE_TTL=45s

# ---- PubSub ----
PUBSUB_IMPL=redis
